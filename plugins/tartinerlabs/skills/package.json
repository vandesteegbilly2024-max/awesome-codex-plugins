    "@semantic-release/changelog": "6.0.3",
    "@semantic-release/git": "10.0.1",
    "@types/node": "22.19.17",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "semantic-release": "25.0.3",
    "typescript": "6.0.3"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": "1.14.24"
  },
  "packageManager": "pnpm@11.0.6",
  "lint-staged": {
